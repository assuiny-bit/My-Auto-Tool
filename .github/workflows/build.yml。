name: Build-Exe
on: [push, workflow_dispatch]
jobs:
  build:
    runs-on: windows-latest
    steps:
    - uses: actions/checkout@v3
    - uses: actions/setup-python@v4
      with:
        python-version: '3.10'
    - name: Install dependencies
      run: pip install pyinstaller pyautogui pillow
    - name: Build exe
      run: pyinstaller --onefile --noconsole test_image.py
    - name: Upload
      uses: actions/upload-artifact@v3
      with:
        name: My-Test-Tool
        path: dist/test_image.exe
